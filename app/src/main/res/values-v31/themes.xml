<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Tester2" parent="android:Theme.Material.Light.NoActionBar">
        <!-- windowBackground shows the splash image before the first Compose frame renders -->
        <item name="android:windowBackground">@drawable/splash_screen_bg</item>
        <!-- Keep the system splash screen minimal on API 31+ — blank icon on plain background -->
        <item name="android:windowSplashScreenBackground">#F9F9F4</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
    </style>
</resources>
